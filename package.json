{
  "name": "hhpc2",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "WATCHPACK_POLLING=true next dev --webpack --experimental-https",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "test": "NODE_NO_WARNINGS=1 vitest run",
    "test:watch": "NODE_NO_WARNINGS=1 vitest",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "env:check": "tsx scripts/check-env.ts",
    "check": "pnpm -s lint && pnpm -s typecheck && pnpm -s test && pnpm -s build",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:status": "supabase status",
    "db:check": "supabase status",
    "db:reset": "supabase db reset",
    "db:migrations:list:local": "supabase migration list --local",
    "db:migrations:list:linked": "supabase migration list --linked",
    "db:push:linked:dry-run": "supabase db push --linked --dry-run",
    "db:push:linked": "supabase db push --linked",
    "db:types:local": "supabase gen types typescript --local > src/types/database.generated.ts",
    "db:types:linked": "supabase gen types typescript --project-id \"$SUPABASE_PROJECT_ID\" > src/types/database.generated.ts",
    "validate:persistence": "tsx scripts/validate-persistence.ts",
    "validate:ingestion": "tsx scripts/validate-ingestion.ts",
    "validate:normalization": "tsx scripts/validate-normalization.ts",
    "validate:events": "tsx scripts/validate-events-and-scoring.ts",
    "validate:api": "tsx scripts/validate-api-layer.ts",
    "validate:supabase": "pnpm -s validate:persistence && pnpm -s validate:ingestion && pnpm -s validate:normalization && pnpm -s validate:events && pnpm -s validate:api"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@supabase/ssr": "^0.7.0",
    "@supabase/supabase-js": "^2.57.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.542.0",
    "motion": "^12.38.0",
    "next": "16.2.1",
    "openai": "^6.33.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "3.8.0",
    "shadcn": "^4.1.1",
    "tailwind-merge": "^3.3.1",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.0.4",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^27.0.0",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "supabase": "^2.54.11",
    "tailwindcss": "^4",
    "tsx": "^4.20.6",
    "typescript": "^5",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  }
}
