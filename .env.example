# Public application metadata
NEXT_PUBLIC_APP_NAME=Crew Readiness
# Use development locally. Hosted demo deployments should set preview or production explicitly.
NEXT_PUBLIC_APP_ENV=development

# Server-side application settings
# Use localhost locally. Hosted demo deployments should set the deployed canonical URL.
APP_URL=http://localhost:3000
AUTH_DEFAULT_ROLE=viewer
FEATURE_ADMIN_TOOLS=false
FEATURE_SIMULATION_CONTROLS=true

# Supabase
# SUPABASE_SERVICE_ROLE_KEY is required for the current server-side query and processing paths.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_PROJECT_ID=your-supabase-project-id

# OpenAI
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL_SUMMARY=gpt-5-mini

# Optional demo protection
DEMO_BASIC_AUTH_USERNAME=
DEMO_BASIC_AUTH_PASSWORD=

# Simulation defaults
SIM_DEFAULT_SEED=42
SIM_DEFAULT_CADENCE_SECONDS=60
SIM_DEFAULT_CREW_COUNT=4
